class=\"dot filled\"></div><div class=\"dot filled\"></div><div class=\"dot\"></div></div></div><div class=\"s-skill\"><span><%= skill4 %></span><div class=\"dots\"><div class=\"dot filled\"></div><div class=\"dot filled\"></div><div class=\"dot filled\"></div><div class=\"dot\"></div><div class=\"dot\"></div></div></div></div><div class=\"gold-line\"></div><div class=\"s-section\"><h3>Education</h3><div class=\"s-item\" style=\"color:#c9a84c;font-weight:500\"><%= degree %></div><div class=\"s-item\"><%= university %></div><div class=\"s-item\"><%= graduationYear %></div></div><div class=\"gold-line\"></div><div class=\"s-section\"><h3>Languages</h3><div class=\"s-item\"><%= lang1 %> — <%= lang1Level %></div><div class=\"s-item\"><%= lang2 %> — <%= lang2Level %></div></div></div><div class=\"main\"><div class=\"main-header\"><div class=\"summary-label\">Professional Profile</div><p><%= summary %></p></div><div class=\"m-section\"><h2><span class=\"gold-dash\"></span>Career History</h2><div class=\"entry\"><div class=\"e-top\"><span class=\"e-title\"><%= job1Title %></span><span class=\"e-date\"><%= job1Start %> – <%= job1End %></span></div><div class=\"e-company\"><%= job1Company %> · <%= job1Location %></div><ul class=\"e-bullets\"><li><%= job1Bullet1 %></li><li><%= job1Bullet2 %></li><li><%= job1Bullet3 %></li></ul></div><div class=\"entry\"><div class=\"e-top\"><span class=\"e-title\"><%= job2Title %></span><span class=\"e-date\"><%= job2Start %> – <%= job2End %></span></div><div class=\"e-company\"><%= job2Company %> · <%= job2Location %></div><ul class=\"e-bullets\"><li><%= job2Bullet1 %></li><li><%= job2Bullet2 %></li></ul></div></div><div class=\"m-section\"><h2><span class=\"gold-dash\"></span>Certifications</h2><div class=\"entry\"><div class=\"e-top\"><span class=\"e-title\"><%= cert1 %></span><span class=\"e-date\"><%= cert1Year %></span></div><div class=\"e-company\"><%= cert1Issuer %></div></div><div class=\"entry\"><div class=\"e-top\"><span class=\"e-title\"><%= cert2 %></span><span class=\"e-date\"><%= cert2Year %></span></div><div class=\"e-company\"><%= cert2Issuer %></div></div></div></div></div></body></html>",
