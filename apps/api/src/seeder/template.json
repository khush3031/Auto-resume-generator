in-bottom:14px}.edu-year{font-size:11px;color:#aaa;text-align:right}.edu-degree{font-size:13px;font-weight:600;color:#1a1a1a}.edu-school{font-size:12px;color:#777}@media print{body{-webkit-print-color-adjust:exact;print-color-adjust:exact}.page{padding:40px}}</style></head><body><div class=\"page\"><div class=\"header\"><h1><%= fullName %></h1><div class=\"title\"><%= jobTitle %></div><div class=\"contact-row\"><span><%= email %></span><span class=\"contact-divider\">·</span><span><%= phone %></span><span class=\"contact-divider\">·</span><span><%= location %></span><span class=\"contact-divider\">·</span><span><%= linkedin %></span></div></div><section><h2>Profile</h2><p class=\"summary\"><%= summary %></p></section><section><h2>Experience</h2><div class=\"exp-item\"><div class=\"exp-meta\"><div class=\"exp-date\"><%= job1Start %> – <%= job1End %></div><div class=\"exp-company\"><%= job1Location %></div></div><div><div class=\"exp-title\"><%= job1Title %></div><div class=\"exp-org\"><%= job1Company %></div><ul class=\"exp-list\"><li><%= job1Bullet1 %></li><li><%= job1Bullet2 %></li><li><%= job1Bullet3 %></li></ul></div></div><div class=\"exp-item\"><div class=\"exp-meta\"><div class=\"exp-date\"><%= job2Start %> – <%= job2End %></div><div class=\"exp-company\"><%= job2Location %></div></div><div><div class=\"exp-title\"><%= job2Title %></div><div class=\"exp-org\"><%= job2Company %></div><ul class=\"exp-list\"><li><%= job2Bullet1 %></li><li><%= job2Bullet2 %></li></ul></div></div></section><section><h2>Education</h2><div class=\"edu-row\"><div class=\"edu-year\"><%= graduationYear %></div><div><div class=\"edu-degree\"><%= degree %></div><div class=\"edu-school\"><%= university %></div></div></div></section><section><h2>Skills</h2><div class=\"skills-grid\"><span class=\"skill-tag\"><%= skill1 %></span><span class=\"skill-tag\"><%= skill2 %></span><span class=\"skill-tag\"><%= skill3 %></span><span class=\"skill-tag\"><%= skill4 %></span><span class=\"skill-tag\"><%= skill5 %></span></div></section><section><h2>Certifications</h2><div class=\"exp-item\" style=\"margin-bottom:10px\"><div class=\"exp-meta\"><div class=\"exp-date\"><%= cert1Year %></div></div><div><div class=\"exp-title\"><%= cert1 %></div><div class=\"exp-org\"><%= cert1Issuer %></div></div></div></section></div></body></html>",
