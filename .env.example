# ----------------------------------------------------------------------
# ResumeForge environment variables reference
# Copy these to apps/api/.env and apps/web/.env.local for local development.
# In production, inject them through your hosting provider instead of a committed file.
# ----------------------------------------------------------------------

# API (apps/api/.env)

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/resumeforge

# JWT secrets. Generate long random values with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# JWT_SECRET is kept as a backward-compatible alias for JWT_ACCESS_SECRET.
JWT_ACCESS_SECRET=change-this-to-a-long-random-string
JWT_SECRET=change-this-to-a-long-random-string
JWT_REFRESH_SECRET=change-this-to-a-different-long-random-string

# Optional token lifetimes
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Keep the request tracker dashboard disabled in production unless you need it temporarily.
ENABLE_REQUEST_TRACKER_DASHBOARD=false

# Leave Chromium sandboxing enabled in production. Only opt out as a temporary workaround.
PDF_ALLOW_UNSAFE_NO_SANDBOX=false

# Anthropic API key for AI suggestions
ANTHROPIC_API_KEY=sk-ant-...

# Port the API listens on (Render injects this automatically)
PORT=3001

# Web (apps/web/.env.local)

# URL of the deployed API, no trailing slash
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional public site URL for metadata and Open Graph generation
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub Actions / hosting secrets
# RENDER_DEPLOY_HOOK_API - Render resumeforge-api deploy hook
# RENDER_DEPLOY_HOOK_WEB - Render resumeforge-web deploy hook
