# ResumeForge Monorepo environment variables

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_SITE_ORIGIN=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-secret
NEXTAUTH_GOOGLE_CLIENT_ID=your-google-client-id
NEXTAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret

# Backend
MONGODB_URI=mongodb://localhost:27017/resumeforge
JWT_SECRET=change-this-secret
CORS_ORIGINS=http://localhost:3000

# Optional Cloudinary for Phase 2
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
