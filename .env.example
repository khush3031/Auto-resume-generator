# ──────────────────────────────────────────────────────────────
# ResumeForge — Environment Variables Reference
# Copy to apps/api/.env and apps/web/.env.local for local dev.
# On Render: add each variable via the Render dashboard.
# ──────────────────────────────────────────────────────────────

# ── API (apps/api/.env) ───────────────────────────────────────

# MongoDB connection string (use MongoDB Atlas for production)
MONGODB_URI=mongodb://localhost:27017/resumeforge

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string
JWT_REFRESH_SECRET=change-this-to-a-different-long-random-string

# Comma-separated list of allowed CORS origins
# Production example: https://resumeforge-web.onrender.com
CORS_ORIGINS=http://localhost:3000

# Anthropic API key for AI suggestions
ANTHROPIC_API_KEY=sk-ant-...

# Port the API listens on (Render injects this automatically)
PORT=3001

# ── Web (apps/web/.env.local) ─────────────────────────────────

# URL of the deployed API — no trailing slash
# Production example: https://resumeforge-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── GitHub Actions Secrets (add in repo Settings → Secrets) ───
# RENDER_DEPLOY_HOOK_API  — from Render dashboard → resumeforge-api → Settings → Deploy Hook
# RENDER_DEPLOY_HOOK_WEB  — from Render dashboard → resumeforge-web → Settings → Deploy Hook
# NEXT_PUBLIC_API_URL     — same value as above, used during CI build
